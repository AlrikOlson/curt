cfg_data = (fs.read "app.cfg") ? "{}"
cfg = cfg_data.json ? {}
name = cfg["name"] ? "?"
orders_data = (fs.read "orders.json") ? "[]"
orders = orders_data.json ? []
paid = orders.keep (o -> o["status"] == "paid")
paid_count = paid.len
total_paid = paid.map (o -> o["amt"]) | sum
print "{name}: {paid_count} paid, total {total_paid}"
