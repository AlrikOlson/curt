```python
count_users = 0
avg_age = 0
with open('users.txt', 'r') as f:
    for line in f:
        fields = line.strip().split(None, 3)
        if len(fields) == 3:
            count_users += 1
            age = int(fields[2])
            avg_age += age
if count_users > 0:
    print(count_users, avg_age // count_users)
