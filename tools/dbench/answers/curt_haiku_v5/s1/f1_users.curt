lines = fs.read "users.txt" ? ""
users = []
for line in lines.lines {
  parts = line.split " " | keep (x -> x.len > 0)
  if parts.len == 3 {
    age = parts[2].int ? null
    if age != null {
      users = users + [{id: parts[0], name: parts[1], age: age}]
    }
  }
}
print users.len
avg = if users.len > 0 { users.map .age | sum / users.len } else { 0 }
print avg
