max_n = 1
max_steps = 0
for n in range 11 {
  if n > 0 {
    x = n
    steps = 0
    while x != 1 {
      if x % 2 == 0 {
        x = x / 2
      } else {
        x = 3 * x + 1
      }
      steps = steps + 1
    }
    if steps > max_steps {
      max_steps = steps
      max_n = n
    }
  }
}
print "{max_n} {max_steps}"
