```cpp
#include <iostream>
#include <vector>
#include <map>

int main() {
    std::vector<int> v = {3, 1, 3, 2, 1, 4};
    std::map<int, int> seen;
    std::vector<int> result;

    for (int elem : v) {
        if (!seen[elem]) {
            seen[elem] = 1;
            result.push_back(elem);
        }
    }

    for (int n : result) {
        std::cout << n << " ";
    }

    return 0;
}
