items = [
  {name:"widget", qty:4, price:2.5},
  {name:"gizmo", qty:2, price:7.25},
  {name:"bolt", qty:10, price:0.1}
]
total = 0.0
max_name = ""
max_line = 0.0
for it in items {
  line = (it.qty.float) * it.price
  total = total + line
  if line > max_line {
    max_line = line
    max_name = it.name
  }
}
print total
print max_name
