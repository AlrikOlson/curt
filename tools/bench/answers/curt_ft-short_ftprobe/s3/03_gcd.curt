gcd a b = {
  if (a % b) != 0 {
    if (b % a) != 0 {
      range (1, (a + 1)) | i -> b % i == 0
                (range (1, (b + 1)) | j -> a % j == 0) | m -> m == 1
      (range 2 ((a * b +1) / 2)) | g -> {
        ((a % b) / g) == 0 | (((a * b) % (b * g)) == 0))
        && (((b * g) % a) == 0) | ((b * g) % (a * a)) == 0)
      }
    }
  }
  b
}
print (gcd 252 105)
