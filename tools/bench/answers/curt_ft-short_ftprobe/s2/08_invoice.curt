items = {"widget": {"qty": 4, "price": 2.5}, "gizmo": {"qty": 2, "price": 7.25}, "bolt": {"qty": 10, "price": 0.1}}
grand_total = ((items["widget"]["qty"] * items["widget"]["price"]) +
  (items["gizmo"]["qty"] * items["gizmo"]["price"]) +
  (items["bolt"]["qty"] * items["bolt"]["price"]))
print "grand total: {total}".format total=grand_total
best = items.most_common(1)[0].name
print best
