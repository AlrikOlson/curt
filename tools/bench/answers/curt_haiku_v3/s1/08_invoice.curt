items = [
  {name: "widget", qty: 4, price: 2.5},
  {name: "gizmo", qty: 2, price: 7.25},
  {name: "bolt", qty: 10, price: 0.1}
]
total = 0.0
best_item = ""
best_line = 0.0
for item in items {
  line = (item.qty).float * item.price
  total += line
  if line > best_line {
    best_line = line
    best_item = item.name
  }
}
print total
print best_item
