collatz_steps n = {
  count = 0
  current = n
  while current != 1 {
    current = if current % 2 == 0 { current / 2 } else { 3 * current + 1 }
    count += 1
  }
  count
}

results = []
for n in range 1 11 {
  steps = collatz_steps n
  results += [{n, steps}]
}

max_result = results | top 1 .steps | first
print "{max_result.n} {max_result.steps} steps"
