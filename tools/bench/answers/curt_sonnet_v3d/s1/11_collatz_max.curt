collatz_steps n = {
  cnt = 0
  cur = n
  while cur != 1 {
    if cur - (cur / 2) * 2 == 0 {
      cur = cur / 2
    } else {
      cur = cur * 3 + 1
    }
    cnt += 1
  }
  cnt
}
best_n = 1
best_steps = 0
for n in range 1 11 {
  s = collatz_steps n
  if s > best_steps {
    best_steps = s
    best_n = n
  }
}
print "{best_n} {best_steps}"
