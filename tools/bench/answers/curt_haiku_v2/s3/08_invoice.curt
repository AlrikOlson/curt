items = [
  {name: "widget", qty: 4, price: 2.5},
  {name: "gizmo", qty: 2, price: 7.25},
  {name: "bolt", qty: 10, price: 0.1}
]
grand_total = 0.0
max_item = ""
max_total = 0.0
for item in items {
  line_total = (item.qty.float) * item.price
  grand_total += line_total
  if line_total > max_total {
    max_total = line_total
    max_item = item.name
  }
}
print grand_total
print max_item
